{
  "kind": "collectionType",
  "collectionName": "kategorien",
  "info": {
    "singularName": "kategorie",
    "pluralName": "kategorien",
    "displayName": "Kategorie",
    "description": "Foto-Kategorien"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "beschreibung": {
      "type": "text"
    },
    "fotos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::foto.foto",
      "mappedBy": "kategorie"
    },
    "icon": {
      "type": "string"
    }
  }
}
